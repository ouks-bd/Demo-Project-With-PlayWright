{
  "name": "pnc-playwright-ts",
  "version": "1.0.0",
  "description": "PNC Bank regression suite – Playwright + TypeScript + POM",
  "scripts": {
    "test":           "playwright test",
    "test:homepage":  "playwright test tests/personalBanking.spec.ts",
    "test:locations": "playwright test tests/locations.spec.ts",
    "test:headed":    "playwright test --headed",
    "test:chromium":  "playwright test --project=Chromium",
    "report":         "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "typescript": "^5.4.0"
  }
}